# ── Configuration Skypeo Scrapper ─────────────────────────────────────────────
# 1. Copiez ce fichier en ".env" (sans le suffixe .example)
# 2. Remplacez la valeur ci-dessous par votre vraie clé API
#
# Obtenir une clé Google Places :
#   https://console.cloud.google.com/ → APIs & Services → Credentials
#   Activez "Places API (New)" dans la bibliothèque d'APIs
#   → $200 de crédit gratuit/mois (couvre largement la collecte)

GOOGLE_PLACES_API_KEY=AIzaSy_REMPLACEZ_PAR_VOTRE_CLE_API
